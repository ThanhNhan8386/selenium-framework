<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Bai 6 Suite" parallel="methods" thread-count="3">
    <parameter name="browser" value="chrome"/>
    <parameter name="env" value="dev"/>
    <listeners>
        <listener class-name="bai6_retry.utils.RetryListener"/>
    </listeners>
    <test name="Bai 6 Tests">
        <classes>
            <class name="bai6_retry.tests.FlakySimulationTest"/>
        </classes>
    </test>
</suite>
