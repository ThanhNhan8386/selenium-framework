<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Smoke Test Suite" parallel="methods" thread-count="2">
    <parameter name="browser" value="chrome"/>
    <parameter name="env" value="dev"/>
    
    <listeners>
        <listener class-name="org.testng.reporters.EmailableReporter"/>
    </listeners>
    
    <test name="Login and Authentication Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="bai2_pom.tests.LoginTest">
                <methods>
                    <include name="testValidLogin"/>
                    <include name="testInvalidLogin"/>
                </methods>
            </class>
            <class name="bai3_excel_ddt.tests.LoginDDTTest">
                <methods>
                    <include name="testLoginSmoke"/>
                </methods>
            </class>
        </classes>
    </test>
    
    <test name="Cart Functionality Tests">
        <classes>
            <class name="bai2_pom.tests.CartTest">
                <methods>
                    <include name="testAddItemToCart"/>
                    <include name="testAddMultipleItemsAndVerify"/>
                </methods>
            </class>
        </classes>
    </test>
    
    <test name="Configuration Tests">
        <classes>
            <class name="bai5_config.tests.ConfigDemoTest"/>
        </classes>
    </test>
</suite>